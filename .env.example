# ─────────────────────────────────────────────────────────────────
# Nifty Pre-Market Briefing MVP — Environment Variable Template
#
# Copy this file to .env and fill in your real values.
# NEVER commit your real .env file to git.
# ─────────────────────────────────────────────────────────────────

# ── Database ──────────────────────────────────────────────────────
# SQLite path for Phase 1. The file will be created automatically.
DATABASE_URL=sqlite:///./data/nifty_premarket.db

# ── Telegram Delivery ─────────────────────────────────────────────
# Get this token from @BotFather on Telegram when you create your bot.
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# The numeric chat ID of the Telegram chat where briefs will be sent.
# You can get this by messaging @userinfobot on Telegram.
TELEGRAM_CHAT_ID=your_telegram_chat_id_here

# ── LLM API (for event classification and brief writing) ──────────
# Used in Milestone 4 onwards. Leave blank until then.
LLM_API_KEY=your_llm_api_key_here
LLM_MODEL=gpt-4o

# ── Application settings ──────────────────────────────────────────
# Set to "development" locally, "production" on your server.
APP_ENV=development

# Log level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# ── Scheduling ────────────────────────────────────────────────────
# Timezone for all scheduled jobs. Do not change this.
SCHEDULER_TIMEZONE=Asia/Kolkata
